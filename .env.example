# Full server endpoint URL.
# Example (same LAN): http://192.168.1.11:5000/api/monitor/push
HARDWARE_PUSH_URL=
HARDWARE_TOKEN=
HARDWARE_DEVICE_NAME=
# --- Daemon (listen + registration URL) ---
# Port the node listens on for fetch requests from the server.
HARDWARE_NODE_LISTEN_PORT=8765
# Bind address (optional; default 0.0.0.0).
# HARDWARE_NODE_LISTEN_HOST=0.0.0.0
# Explicit URL the server should use to reach this node (auto-detected if empty).
# Example: http://192.168.1.22:8765
HARDWARE_NODE_URL=

# Legacy names (still read if the variables above are unset):
# HARDWARE_PULL_PORT, HARDWARE_PULL_HOST, HARDWARE_CLIENT_URL
